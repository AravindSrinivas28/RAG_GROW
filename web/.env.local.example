# Base URL of the FastAPI app (`m1-rag-api`). No trailing slash. Use https in production.
NEXT_PUBLIC_M1_RAG_API_URL=http://127.0.0.1:8000
# Example (Render): NEXT_PUBLIC_M1_RAG_API_URL=https://your-service.onrender.com

# Optional (Vercel + Safari / “Load failed”): browser calls same-origin /api/m1/*; Next.js proxies to Render.
# Requires NEXT_PUBLIC_M1_RAG_API_URL so next.config rewrites know the upstream. Then redeploy.
# NEXT_PUBLIC_API_VIA_VERCEL_PROXY=1
