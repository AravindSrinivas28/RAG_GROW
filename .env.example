# Copy to .env and fill values locally. Never commit .env.
# GitHub Actions: add the same names as repository secrets (see phases/phase_0_foundation/SECRETS.md).

# --- API keys ---
# Optional: only if you wire a hosted embedding API (default ingest uses local BAAI/bge-small-en-v1.5).
# M1_RAG_EMBEDDING_API_KEY=

# Phase 6+ chat LLM (OpenRouter is default — config/default.yaml llm.api_base).
# Use ONE of the following (OpenRouter key is preferred when both are set):
M1_RAG_OPENROUTER_API_KEY=
# M1_RAG_LLM_API_KEY=

# --- HTTP API (m1-rag-api) — if port 8000 is already in use by another app ---
# M1_RAG_API_HOST=127.0.0.1
# M1_RAG_API_PORT=8765

# --- Optional: path to YAML config (default: config/default.yaml from project root) ---
# M1_RAG_CONFIG_FILE=/absolute/path/to/config/default.yaml

# --- Optional: override app environment ---
# M1_RAG_APP_ENV=production

# --- Phase 9: logging (API chat JSON lines on logger m1_rag.chat) ---
# M1_RAG_LOG_LEVEL=INFO
